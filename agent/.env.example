# YieldMind Agent — Cloudflare Worker env vars
# Usage: cp .env.example .env && fill in values
# Then set secrets: wrangler secret put AGENT_PRIVATE_KEY

# Deployer private key (stores as Cloudflare secret, not in wrangler.toml)
AGENT_PRIVATE_KEY=

# DGrid AI Gateway API key for natural language strategy parsing
DGRID_API_KEY=

# Comma-separated list of user addresses to monitor and rebalance
# Example: 0x4Ba1e9e275EF61B56C99532D0066506436201D73,0xAbC...
WATCHED_USERS=
